{
  "name": "chat-app-backend",
  "version": "1.0.0",
  "description": "Production-style backend for a chat application",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "lint": "eslint .",
    "check": "find src public test -name '*.js' -print0 | xargs -0 -n1 node --check",
    "test": "node --test test/**/*.test.js"
