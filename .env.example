NODE_ENV=development
PORT=5000
APP_NAME=chat-app

MONGO_URI=mongodb://127.0.0.1:27017/chat_app
JWT_ACCESS_SECRET=your_access_secret
JWT_REFRESH_SECRET=your_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

CLIENT_URL=http://localhost:3000
EMAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
BCRYPT_SALT_ROUNDS=10

SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_AUTH_METHOD=oauth2
SMTP_USER=your_outlook_email
SMTP_PASS=
SMTP_FROM=your_outlook_email
SMTP_OAUTH2_CLIENT_ID=
SMTP_OAUTH2_CLIENT_SECRET=
SMTP_OAUTH2_REFRESH_TOKEN=
SMTP_OAUTH2_ACCESS_TOKEN=
SMTP_OAUTH2_TENANT_ID=

STORAGE_DRIVER=local
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20
